# ==========================================
# Root .gitignore for AdPulse Project
# ==========================================

# OS Files
.DS_Store
Thumbs.db
*.lnk

# Editor/IDE
.vscode/
client/.vscode/
settings.yaml
extensions.yaml
*.png
.idea/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment Variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Cypress
cypress/screenshots/
cypress/videos/
client/cypress/screenshots/
client/cypress/videos/

# Node / JS / Client
node_modules/
dist/
dist-ssr/
build/
*.tsbuildinfo
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Java / Maven / Backend
target/
*.jar
*.war
*.ear
*.class
.mvn/
!/.mvn/wrapper/maven-wrapper.properties
.checkstyle
.pmd
.factorypath