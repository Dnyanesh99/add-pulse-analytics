# Redis
REDIS_PASSWORD=change_me_redis

# ClickHouse
CLICKHOUSE_DB=adpulse
CLICKHOUSE_USER=adpulse
CLICKHOUSE_PASSWORD=change_me_clickhouse

# SHA-256 hash of CLICKHOUSE_PASSWORD (used in users.xml).
# Generate: echo -n 'your_password' | sha256sum | tr -d ' -'
CLICKHOUSE_PASSWORD_SHA256=replace_with_sha256_of_clickhouse_password
